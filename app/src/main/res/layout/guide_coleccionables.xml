<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/highlight_ring_coleccionables"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/anillo_destaque"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.84"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/iv_arrow_coleccionables"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginBottom="8dp"
        android:rotation="45"
        android:src="@android:drawable/arrow_down_float"
        app:tint="#B948C7"
        app:layout_constraintBottom_toTopOf="@+id/highlight_ring_coleccionables"
        app:layout_constraintEnd_toEndOf="@+id/highlight_ring_coleccionables"
        app:layout_constraintStart_toStartOf="@+id/highlight_ring_coleccionables" />

    <TextView
        android:id="@+id/tv_bocadillo_coleccionables"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bocadillo"
        android:paddingHorizontal="32dp"
        android:paddingVertical="48dp"
        android:text="¡Gemas, orbes y talismanes! Descubre todos los tesoros que has recolectado en tu aventura."
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/iv_arrow_coleccionables"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>