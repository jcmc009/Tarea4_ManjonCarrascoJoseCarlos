<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/highlight_ring_info"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/anillo_destaque"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_arrow_info"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:rotation="180"
        android:src="@android:drawable/arrow_down_float"
        app:tint="#B948C7"
        app:layout_constraintEnd_toEndOf="@+id/highlight_ring_info"
        app:layout_constraintStart_toStartOf="@+id/highlight_ring_info"
        app:layout_constraintTop_toBottomOf="@+id/highlight_ring_info" />

    <TextView
        android:id="@+id/tv_bocadillo_info"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bocadillo"
        android:paddingHorizontal="32dp"
        android:paddingVertical="48dp"
        android:text="¿Necesitas ayuda o quieres saber más sobre la app? Pulsa este icono de información en cualquier momento."
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_arrow_info" />

</androidx.constraintlayout.widget.ConstraintLayout>